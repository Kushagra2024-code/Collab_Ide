# ============================================================
# CollabIDE — Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string.
# For Docker Compose (recommended): use the service name "postgres"
#   DATABASE_URL=postgresql://collabide:collabide@postgres:5432/collabide
# For local PostgreSQL:
#   DATABASE_URL=postgresql://user:password@localhost:5432/collabide
DATABASE_URL=postgresql://collabide:collabide@postgres:5432/collabide

# ── Auth ─────────────────────────────────────────────────────
# Secret for signing JWT tokens. MUST be long, random, secret.
# Generate one: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── AI / Gemini ───────────────────────────────────────────────
# Your Google Gemini API key.
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Server ───────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Frontend (used at BUILD time) ────────────────────────────
# The base path where the frontend is served.
# Use "/" for root, or "/collab-ide" for sub-path.
VITE_BASE_PATH=/

# ── Optional: Docker Sandbox ─────────────────────────────────
# Set to "true" to use Docker containers for terminal isolation.
# Requires Docker daemon running and the api-server to have Docker socket access.
SANDBOX_DOCKER=false
SANDBOX_IMAGE=ubuntu:22.04

# ── Optional: Yjs Persistence ────────────────────────────────
# Port for the embedded y-websocket server (defaults to PORT+1 = 8081)
# YJS_PORT=8081
# Directory for LevelDB persistence of Yjs documents
# YJS_STORAGE_PATH=/data/yjs

# ── Optional: Redis (for horizontal scaling) ─────────────────
# Uncomment if you add Redis for Socket.IO adapter
# REDIS_URL=redis://localhost:6379
